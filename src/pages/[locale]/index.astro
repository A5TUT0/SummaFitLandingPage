---
import BaseLayout from '../../components/BaseLayout.astro';
import { LandingExperience } from '../../components/LandingExperience';
import { COPY, SUPPORTED_LOCALES, type Locale } from '../../lib/i18n';
import { Image } from 'astro:assets';
import heroImage from '../../../public/images/heroImage.png';

export function getStaticPaths() {
  return SUPPORTED_LOCALES.filter(locale => locale !== 'en').map((locale) => ({
    params: { locale },
  }));
}

const { locale } = Astro.params;
const INSTALL_URL = 'https://apps.apple.com/app/id6787150982';
const copy = COPY[locale as Locale];
---

<BaseLayout locale={locale as Locale} copy={copy}>
  <section class="hero" aria-labelledby="hero-title">
    <LandingExperience client:load installUrl={INSTALL_URL} copy={copy} />
    <div class="hero-media reveal-phone" aria-label="SummaFit app preview">
      <div class="phone-shadow" aria-hidden="true" />
      <Image
        src={heroImage}
        alt={copy.heroAlt}
        class="hero-product-image"
        loading="eager"
        fetchpriority="high"
        widths={[400, 800, 1080]}
        sizes="(max-width: 800px) 400px, (max-width: 1200px) 800px, 1080px"
      />
    </div>
  </section>
  <section class="sr-only">
    <h2>{copy.seoTitle}</h2>
    <p>{copy.seoDescription}</p>
    <h3>{copy.title}</h3>
    <p>{copy.subtitle}</p>
  </section>
</BaseLayout>
