---
import BaseLayout from '../../components/BaseLayout.astro';
import { LandingExperience } from '../../components/LandingExperience';
import { COPY, SUPPORTED_LOCALES, localizedPath, type Locale } from '../../lib/i18n';

import HeroCarousel from '../../components/HeroCarousel';
import FluidGlass from '../../components/FluidGlass/FluidGlass.jsx';

export function getStaticPaths() {
  return SUPPORTED_LOCALES.map((locale) => ({
    params: { locale },
  }));
}

const { locale } = Astro.params;
const copy = COPY[locale as Locale];
const { content: _content, ...heroCopy } = copy;
const privacyHref = localizedPath(locale as Locale, "/policy");
const supportHref = localizedPath(locale as Locale, "/support");
---

<BaseLayout locale={locale as Locale} copy={copy}>
  <section class="hero" aria-labelledby="hero-title">
    <LandingExperience installUrl="" privacyHref={privacyHref} supportHref={supportHref} copy={heroCopy} highlights={copy.content.highlights} />
    <figure class="hero-media reveal-phone" aria-label={copy.heroAlt}>
      <div class="phone-shadow" aria-hidden="true" />
      <HeroCarousel />
    </figure>
  </section>
  <div class="fluid-glass-demo" style={{ height: '600px', position: 'relative' }}>
    <FluidGlass
      client:only="react"
      mode="lens"
      lensProps={{
        scale: 0.25,
        ior: 1.15,
        thickness: 5,
        chromaticAberration: 0.1,
        anisotropy: 0.01,
      }}
      barProps={{}}
      cubeProps={{}}
    />
  </div>
</BaseLayout>
