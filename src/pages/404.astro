---
import "../styles/global.css";
import { LOCALE_LABELS, SUPPORTED_LOCALES, localizedPath } from "../lib/i18n";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, follow" />
    <meta name="theme-color" content="#F5F7FA" />
    <link rel="icon" href="/logo.svg" type="image/svg+xml" />
    <title>Page not found | SummaFit</title>
  </head>
  <body class="not-found-page">
    <main>
      <a class="brand" href="/en/" aria-label="SummaFit home">
        <img src="/logo.svg" alt="" width="34" height="34" />
        <span>SummaFit</span>
      </a>
      <p class="not-found-code">404</p>
      <h1>Page not found</h1>
      <p>The page you requested does not exist. Choose a language to continue.</p>
      <nav aria-label="Choose language">
        {
          SUPPORTED_LOCALES.map((locale) => (
            <a href={localizedPath(locale)} hreflang={locale} lang={locale}>
              {LOCALE_LABELS[locale]}
            </a>
          ))
        }
      </nav>
    </main>
  </body>
</html>
