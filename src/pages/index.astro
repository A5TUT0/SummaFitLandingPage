---
import BaseLayout from '../components/BaseLayout.astro';
import { LandingExperience } from '../components/LandingExperience';
import { COPY, type Locale } from '../lib/i18n';

import HeroCarousel from '../components/HeroCarousel';

const locale: Locale = 'en';
const INSTALL_URL = 'https://apps.apple.com/app/id6787150982';
const copy = COPY[locale];
---

<BaseLayout locale={locale} copy={copy}>
  <section class="hero" aria-labelledby="hero-title">
    <LandingExperience client:load installUrl={INSTALL_URL} copy={copy} />
    <div class="hero-media reveal-phone" aria-label="SummaFit app preview">
      <div class="phone-shadow" aria-hidden="true" />
      <HeroCarousel client:load />
    </div>
  </section>
  <section class="sr-only">
    <h2>{copy.seoTitle}</h2>
    <p>{copy.seoDescription}</p>
    <h3>{copy.title}</h3>
    <p>{copy.subtitle}</p>
  </section>
</BaseLayout>
