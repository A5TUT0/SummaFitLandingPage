---
import '../styles/global.css';
import {
  Activity,
  Apple,
  ArrowRight,
  BarChart3,
  Bell,
  Camera,
  Check,
  ChevronRight,
  Droplets,
  Flame,
  HeartPulse,
  Home,
  Plus,
  Salad,
  ScanLine,
  ShieldCheck,
  Sparkles,
  Target,
  Utensils,
} from 'lucide-astro';

const macros = [
  { label: 'Proteina', value: '118g', percent: '82%', color: 'var(--purple-main)' },
  { label: 'Carbs', value: '164g', percent: '67%', color: 'var(--cyan-main)' },
  { label: 'Grasas', value: '54g', percent: '73%', color: 'var(--fat-main)' },
];

const meals = [
  { name: 'Bowl mediterraneo', time: '12:40', calories: '520 kcal', icon: Salad },
  { name: 'Yogur + frutos rojos', time: '09:15', calories: '240 kcal', icon: Apple },
  { name: 'Cafe proteico', time: '07:50', calories: '160 kcal', icon: Utensils },
];

const features = [
  {
    icon: ScanLine,
    title: 'Registro sin friccion',
    copy: 'Escanea, dicta o toca una comida frecuente. SummaFit completa calorias y macros con una vista clara del dia.',
  },
  {
    icon: Droplets,
    title: 'Hidratacion visible',
    copy: 'Botones rapidos para vasos y botellas, progreso por meta y recordatorios suaves cuando tu ritmo baja.',
  },
  {
    icon: HeartPulse,
    title: 'Habitos diarios',
    copy: 'Une nutricion, agua, movimiento y constancia en una rutina simple que se siente premium y ligera.',
  },
];
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="SummaFit es una app moderna de seguimiento nutricional, hidratacion y habitos diarios con una experiencia suave tipo iOS."
    />
    <title>SummaFit | Nutricion y habitos diarios</title>
  </head>
  <body>
    <div class="soft-grid pointer-events-none fixed inset-0 z-0"></div>

    <header class="fixed left-0 right-0 top-4 z-50 px-4">
      <nav
        class="glass-nav mx-auto flex h-16 max-w-6xl items-center justify-between rounded-full px-4 sm:px-6"
        aria-label="Principal"
      >
        <a href="#" class="flex items-center gap-3" aria-label="SummaFit inicio">
          <span
            class="grid size-10 place-items-center rounded-full bg-[var(--orange-main)] text-white shadow-[0_10px_22px_var(--orange-glow)]"
          >
            <Flame size={21} strokeWidth={2.5} />
          </span>
          <span class="text-lg font-semibold tracking-normal">SummaFit</span>
        </a>
        <div class="hidden items-center gap-7 text-sm font-medium text-[var(--text-secondary)] md:flex">
          <a class="transition hover:text-[var(--text-main)]" href="#features">Funciones</a>
          <a class="transition hover:text-[var(--text-main)]" href="#daily">Rutina</a>
          <a class="transition hover:text-[var(--text-main)]" href="#results">Progreso</a>
        </div>
        <a
          href="#download"
          class="inline-flex h-11 items-center gap-2 rounded-full bg-[var(--text-main)] px-5 text-sm font-semibold text-white shadow-lg shadow-black/10 transition hover:-translate-y-0.5"
        >
          Probar app
          <ArrowRight size={17} />
        </a>
      </nav>
    </header>

    <main class="relative z-10">
      <section class="min-h-screen px-4 pb-16 pt-28 sm:px-6 lg:px-8 lg:pt-32">
        <div class="mx-auto grid max-w-6xl items-center gap-12 lg:grid-cols-[0.96fr_1.04fr]">
          <div class="hero-copy max-w-2xl">
            <div
              class="mb-6 inline-flex items-center gap-2 rounded-full border border-white/70 bg-white/70 px-4 py-2 text-sm font-semibold text-[var(--orange-deep)] shadow-sm backdrop-blur"
            >
              <Sparkles size={16} />
              Nutricion, agua y habitos en una sola vista
            </div>
            <h1 class="max-w-3xl text-5xl font-semibold leading-[1.02] tracking-normal text-[var(--text-main)] sm:text-6xl lg:text-7xl">
              SummaFit
            </h1>
            <p class="mt-6 max-w-xl text-lg leading-8 text-[var(--text-secondary)] sm:text-xl">
              Una experiencia premium para seguir calorias, macros, hidratacion y comidas del dia sin ruido visual. Limpia, suave y hecha para volver a ella todos los dias.
            </p>
            <div class="mt-9 flex flex-col gap-4 sm:flex-row">
              <a
                href="#download"
                class="inline-flex h-14 items-center justify-center gap-3 rounded-full bg-[var(--orange-main)] px-7 text-base font-semibold text-white shadow-[0_14px_34px_var(--orange-glow)] transition hover:-translate-y-1"
              >
                Empezar seguimiento
                <ChevronRight size={20} />
              </a>
              <a
                href="#features"
                class="inline-flex h-14 items-center justify-center gap-3 rounded-full border border-white/80 bg-white/70 px-7 text-base font-semibold text-[var(--text-main)] shadow-sm backdrop-blur transition hover:-translate-y-1"
              >
                Ver funciones
                <BarChart3 size={19} />
              </a>
            </div>
            <div class="mt-10 grid max-w-xl grid-cols-3 gap-3">
              <div class="stat rounded-[28px] border border-white/70 bg-white/60 p-4 backdrop-blur">
                <p class="text-2xl font-semibold">92%</p>
                <p class="mt-1 text-sm text-[var(--text-secondary)]">dias completos</p>
              </div>
              <div class="stat rounded-[28px] border border-white/70 bg-white/60 p-4 backdrop-blur">
                <p class="text-2xl font-semibold">2.4L</p>
                <p class="mt-1 text-sm text-[var(--text-secondary)]">agua objetivo</p>
              </div>
              <div class="stat rounded-[28px] border border-white/70 bg-white/60 p-4 backdrop-blur">
                <p class="text-2xl font-semibold">14k</p>
                <p class="mt-1 text-sm text-[var(--text-secondary)]">pasos activos</p>
              </div>
            </div>
          </div>

          <div class="hero-visual relative mx-auto w-full max-w-[560px]">
            <div
              class="float-card card absolute -left-2 top-16 z-20 hidden w-44 p-5 sm:block lg:-left-10"
            >
              <div class="flex items-center gap-3">
                <span class="grid size-11 place-items-center rounded-full bg-[var(--blue-soft)] text-[var(--blue-main)]">
                  <Droplets size={22} />
                </span>
                <div>
                  <p class="text-sm font-semibold">Hidratacion</p>
                  <p class="text-xs text-[var(--text-secondary)]">1.8 / 2.4 L</p>
                </div>
              </div>
              <div class="mt-4 h-2 overflow-hidden rounded-full bg-[var(--blue-soft)]">
                <div class="h-full w-3/4 rounded-full bg-[var(--blue-main)]"></div>
              </div>
            </div>

            <div
              class="float-card card absolute -right-1 bottom-28 z-20 hidden w-48 p-5 sm:block lg:-right-8"
            >
              <div class="flex items-center justify-between">
                <span class="grid size-11 place-items-center rounded-full bg-green-50 text-[var(--green-main)]">
                  <Activity size={22} />
                </span>
                <span class="rounded-full bg-green-50 px-3 py-1 text-xs font-semibold text-[var(--green-main)]">+18%</span>
              </div>
              <p class="mt-4 text-sm text-[var(--text-secondary)]">Calorias quemadas</p>
              <p class="mt-1 text-2xl font-semibold">640</p>
            </div>

            <div class="phone-shell motion-safe relative mx-auto w-full max-w-[390px] rounded-[48px] border border-white/80 bg-[#f7f8fa] p-3">
              <div class="overflow-hidden rounded-[38px] border border-[#eceef1] bg-[#f7f8fa]">
                <div class="px-5 pb-5 pt-4">
                  <div class="mb-5 flex items-center justify-between">
                    <div>
                      <p class="text-sm text-[var(--text-secondary)]">Hoy</p>
                      <p class="text-xl font-semibold">Resumen diario</p>
                    </div>
                    <button
                      class="grid size-11 place-items-center rounded-full border border-[#eaebee] bg-white text-[var(--text-main)] shadow-sm"
                      aria-label="Notificaciones"
                    >
                      <Bell size={19} />
                    </button>
                  </div>

                  <section class="card p-5">
                    <div class="flex items-center justify-between">
                      <div>
                        <p class="text-sm font-medium text-[var(--text-secondary)]">Calorias</p>
                        <p class="mt-1 text-4xl font-semibold tracking-normal">1,680</p>
                        <p class="mt-1 text-sm text-[var(--text-muted)]">de 2,180 kcal</p>
                      </div>
                      <div class="ring-progress grid size-28 place-items-center rounded-full">
                        <div class="grid size-20 place-items-center rounded-full bg-white">
                          <Flame size={30} class="text-[var(--orange-main)]" />
                        </div>
                      </div>
                    </div>
                    <div class="mt-5 grid grid-cols-3 gap-2">
                      {macros.map((macro) => (
                        <div class="rounded-[22px] bg-[#f7f8fa] p-3">
                          <p class="text-[11px] font-medium text-[var(--text-secondary)]">{macro.label}</p>
                          <p class="mt-1 text-base font-semibold">{macro.value}</p>
                          <div class="mt-2 h-1.5 rounded-full bg-[var(--ring-bg)]">
                            <div
                              class="h-full rounded-full"
                              style={`width:${macro.percent}; background:${macro.color}`}
                            >
                            </div>
                          </div>
                        </div>
                      ))}
                    </div>
                  </section>

                  <section class="card mt-4 p-5">
                    <div class="flex items-center justify-between">
                      <div>
                        <p class="text-sm font-semibold">Agua</p>
                        <p class="mt-1 text-sm text-[var(--text-secondary)]">6 de 8 vasos</p>
                      </div>
                      <button class="water-button inline-flex items-center gap-2 text-sm font-semibold">
                        <Plus size={17} />
                        250 ml
                      </button>
                    </div>
                    <div class="mt-4 grid grid-cols-8 gap-1.5">
                      {Array.from({ length: 8 }).map((_, index) => (
                        <span
                          class:list={[
                            'h-9 rounded-full',
                            index < 6 ? 'bg-[var(--blue-main)]' : 'bg-[var(--blue-soft)]',
                          ]}
                        />
                      ))}
                    </div>
                  </section>

                  <section class="card mt-4 p-5">
                    <div class="mb-4 flex items-center justify-between">
                      <p class="font-semibold">Comidas</p>
                      <button class="grid size-9 place-items-center rounded-full bg-[var(--orange-main)] text-white" aria-label="Anadir comida">
                        <Plus size={18} />
                      </button>
                    </div>
                    <div class="space-y-3">
                      {meals.map((meal) => (
                        <div class="flex items-center gap-3 rounded-[24px] bg-[#f7f8fa] p-3">
                          <span class="grid size-11 place-items-center rounded-full bg-white text-[var(--orange-main)] shadow-sm">
                            <meal.icon size={20} />
                          </span>
                          <div class="min-w-0 flex-1">
                            <p class="truncate text-sm font-semibold">{meal.name}</p>
                            <p class="text-xs text-[var(--text-secondary)]">{meal.time}</p>
                          </div>
                          <p class="text-xs font-semibold text-[var(--text-secondary)]">{meal.calories}</p>
                        </div>
                      ))}
                    </div>
                  </section>
                </div>

                <div class="px-5 pb-5">
                  <div class="bottom-nav grid grid-cols-4 items-center gap-1 p-1.5">
                    <button class="grid h-12 place-items-center rounded-full bg-[#f2f2f2] text-[var(--orange-main)]" aria-label="Inicio">
                      <Home size={20} />
                    </button>
                    <button class="grid h-12 place-items-center rounded-full text-[var(--text-muted)]" aria-label="Actividad">
                      <Activity size={20} />
                    </button>
                    <button class="mx-auto grid size-16 -translate-y-5 place-items-center rounded-full bg-gradient-to-b from-[#f26a00] to-[#d84b00] text-white shadow-[0_12px_32px_rgba(216,75,0,0.38)]" aria-label="Escanear comida">
                      <Camera size={24} />
                    </button>
                    <button class="grid h-12 place-items-center rounded-full text-[var(--text-muted)]" aria-label="Objetivos">
                      <Target size={20} />
                    </button>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section id="features" class="px-4 py-20 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-6xl">
          <div class="section-title max-w-2xl">
            <p class="text-sm font-semibold uppercase text-[var(--orange-deep)]">Funciones clave</p>
            <h2 class="mt-3 text-4xl font-semibold tracking-normal sm:text-5xl">
              Todo lo importante queda visible sin sentirse pesado.
            </h2>
          </div>
          <div class="mt-10 grid gap-5 md:grid-cols-3">
            {features.map((feature) => (
              <article class="feature-card card p-7">
                <span class="grid size-13 place-items-center rounded-full bg-[#f7f8fa] text-[var(--orange-main)]">
                  <feature.icon size={24} />
                </span>
                <h3 class="mt-6 text-xl font-semibold">{feature.title}</h3>
                <p class="mt-3 leading-7 text-[var(--text-secondary)]">{feature.copy}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section id="daily" class="px-4 py-20 sm:px-6 lg:px-8">
        <div class="mx-auto grid max-w-6xl items-center gap-8 lg:grid-cols-[0.9fr_1.1fr]">
          <div class="section-title">
            <p class="text-sm font-semibold uppercase text-[var(--blue-main)]">Rutina diaria</p>
            <h2 class="mt-3 text-4xl font-semibold tracking-normal sm:text-5xl">
              Acciones rapidas para mantener el dia bajo control.
            </h2>
            <p class="mt-5 text-lg leading-8 text-[var(--text-secondary)]">
              La landing refleja la app: botones claros, tarjetas suaves, estados reconocibles y acentos fuertes solo donde importan.
            </p>
          </div>
          <div class="grid gap-4 sm:grid-cols-2">
            <div class="routine-card card p-7">
              <div class="flex items-center justify-between">
                <span class="grid size-12 place-items-center rounded-full bg-[var(--blue-soft)] text-[var(--blue-main)]">
                  <Droplets size={24} />
                </span>
                <span class="text-sm font-semibold text-[var(--blue-main)]">75%</span>
              </div>
              <h3 class="mt-8 text-2xl font-semibold">Hidratacion</h3>
              <div class="mt-5 h-3 overflow-hidden rounded-full bg-[var(--blue-soft)]">
                <div class="h-full w-3/4 rounded-full bg-[var(--blue-main)]"></div>
              </div>
            </div>
            <div class="routine-card card p-7">
              <div class="flex items-center justify-between">
                <span class="grid size-12 place-items-center rounded-full bg-orange-50 text-[var(--orange-main)]">
                  <Flame size={24} />
                </span>
                <span class="text-sm font-semibold text-[var(--orange-deep)]">500 kcal libres</span>
              </div>
              <h3 class="mt-8 text-2xl font-semibold">Energia</h3>
              <p class="mt-3 leading-7 text-[var(--text-secondary)]">Un anillo simple resume lo que llevas consumido y lo que queda para la meta.</p>
            </div>
            <div class="routine-card card p-7 sm:col-span-2">
              <div class="flex flex-col gap-5 sm:flex-row sm:items-center sm:justify-between">
                <div>
                  <h3 class="text-2xl font-semibold">Habitos completados</h3>
                  <p class="mt-2 text-[var(--text-secondary)]">Desayuno, agua, caminata y cena ligera.</p>
                </div>
                <div class="flex gap-2">
                  {Array.from({ length: 4 }).map(() => (
                    <span class="grid size-12 place-items-center rounded-full bg-green-50 text-[var(--green-main)]">
                      <Check size={20} />
                    </span>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section id="results" class="px-4 py-20 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-6xl">
          <div class="card overflow-hidden p-6 sm:p-8 lg:p-10">
            <div class="grid gap-10 lg:grid-cols-[0.85fr_1.15fr] lg:items-center">
              <div class="section-title">
                <p class="text-sm font-semibold uppercase text-[var(--green-main)]">Progreso</p>
                <h2 class="mt-3 text-4xl font-semibold tracking-normal sm:text-5xl">
                  Claridad semanal sin dashboards frios.
                </h2>
                <p class="mt-5 text-lg leading-8 text-[var(--text-secondary)]">
                  SummaFit convierte calorias, macros y habitos en una lectura amable: suficiente detalle para decidir, cero saturacion.
                </p>
              </div>
              <div class="grid gap-4 sm:grid-cols-3">
                {[
                  ['Calorias', '89%', 'var(--orange-main)'],
                  ['Proteina', '94%', 'var(--purple-main)'],
                  ['Agua', '76%', 'var(--blue-main)'],
                ].map(([label, value, color]) => (
                  <div class="progress-card rounded-[30px] border border-[#eceef1] bg-[#f7f8fa] p-5">
                    <div class="mx-auto grid size-28 place-items-center rounded-full" style={`background: conic-gradient(${color} 0 ${value}, #eceef1 ${value} 100%)`}>
                      <div class="grid size-20 place-items-center rounded-full bg-white">
                        <span class="text-xl font-semibold">{value}</span>
                      </div>
                    </div>
                    <p class="mt-5 text-center font-semibold">{label}</p>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </section>

      <section id="download" class="px-4 py-24 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-4xl text-center">
          <div class="section-title">
            <p class="text-sm font-semibold uppercase text-[var(--orange-deep)]">Lanzamiento</p>
            <h2 class="mt-3 text-4xl font-semibold tracking-normal sm:text-6xl">
              Seguimiento nutricional que da gusto abrir.
            </h2>
            <p class="mx-auto mt-5 max-w-2xl text-lg leading-8 text-[var(--text-secondary)]">
              Una landing lista para presentar SummaFit con una estética health premium, mucho aire y animaciones suaves.
            </p>
          </div>
          <div class="mt-9 flex flex-col items-center justify-center gap-4 sm:flex-row">
            <a
              href="mailto:hola@summafit.app"
              class="inline-flex h-14 items-center justify-center gap-3 rounded-full bg-[var(--orange-main)] px-8 text-base font-semibold text-white shadow-[0_14px_34px_var(--orange-glow)] transition hover:-translate-y-1"
            >
              Solicitar acceso
              <ArrowRight size={20} />
            </a>
            <a
              href="#"
              class="inline-flex h-14 items-center justify-center gap-3 rounded-full border border-white/80 bg-white/70 px-8 text-base font-semibold text-[var(--text-main)] shadow-sm backdrop-blur transition hover:-translate-y-1"
            >
              <ShieldCheck size={20} />
              App privada beta
            </a>
          </div>
        </div>
      </section>
    </main>

    <script>
      import { gsap } from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';

      gsap.registerPlugin(ScrollTrigger);

      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (!prefersReduced) {
        gsap
          .timeline({ defaults: { ease: 'power3.out' } })
          .from('.glass-nav', { y: -24, opacity: 0, duration: 0.8 })
          .from('.hero-copy > *', { y: 28, opacity: 0, duration: 0.8, stagger: 0.08 }, '-=0.35')
          .from('.phone-shell', { y: 44, rotate: -2, opacity: 0, duration: 1 }, '-=0.55')
          .from('.float-card', { scale: 0.9, y: 24, opacity: 0, duration: 0.75, stagger: 0.12 }, '-=0.55');

        gsap.to('.phone-shell', {
          y: -16,
          rotate: 1.2,
          duration: 4.4,
          repeat: -1,
          yoyo: true,
          ease: 'sine.inOut',
        });

        gsap.to('.float-card', {
          y: -12,
          duration: 3.3,
          repeat: -1,
          yoyo: true,
          stagger: 0.35,
          ease: 'sine.inOut',
        });

        gsap.utils
          .toArray<HTMLElement>('.section-title, .feature-card, .routine-card, .progress-card')
          .forEach((element) => {
            gsap.from(element, {
              y: 32,
              opacity: 0,
              duration: 0.8,
              ease: 'power3.out',
              scrollTrigger: {
                trigger: element,
                start: 'top 82%',
              },
            });
          });

        gsap.to('.ring-progress', {
          rotate: 360,
          duration: 18,
          repeat: -1,
          ease: 'none',
        });
      }
    </script>
  </body>
</html>
