---
import '../styles/global.css';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="SummaFit es una experiencia minimalista para seguimiento nutricional." />
    <title>SummaFit</title>
  </head>
  <body>
    <div class="ambient-field" aria-hidden="true">
      <span class="ambient-glow glow-orange"></span>
      <span class="ambient-glow glow-violet"></span>
      <span class="ambient-glow glow-green"></span>
      <span class="ambient-glow glow-blue"></span>
    </div>

    <main class="page-shell">
      <header class="site-header reveal-soft">
        <a class="brand" href="/" aria-label="SummaFit inicio">SummaFit</a>
      </header>

      <section class="hero" aria-labelledby="hero-title">
        <div class="hero-inner">
          <p class="eyebrow reveal-soft">Private beta</p>
          <h1 id="hero-title" class="title reveal-soft">Nutrition tracking, quiet by design.</h1>
          <p class="subtitle reveal-soft">
            SummaFit keeps calories, macros, water, and daily habits in one focused space.
            No noise. No clutter. Just the essentials.
          </p>
          <div class="actions reveal-soft">
            <a class="button" href="mailto:hola@summafit.app">Request access</a>
          </div>
        </div>
      </section>
    </main>

    <script>
      import { gsap } from 'gsap';

      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (!prefersReducedMotion) {
        gsap.set('.reveal-soft', { opacity: 0, y: 18, filter: 'blur(12px)' });
        gsap.to('.reveal-soft', {
          opacity: 1,
          y: 0,
          filter: 'blur(0px)',
          duration: 1.05,
          stagger: 0.11,
          ease: 'power3.out',
          delay: 0.08,
        });

        gsap.to('.ambient-glow', {
          scale: 1.08,
          opacity: 0.72,
          duration: 5.8,
          repeat: -1,
          yoyo: true,
          ease: 'sine.inOut',
          stagger: { each: 0.55, yoyo: true, repeat: -1 },
        });

        gsap.to('.glow-orange', { x: 14, y: 10, duration: 7.5, repeat: -1, yoyo: true, ease: 'sine.inOut' });
        gsap.to('.glow-violet', { x: -12, y: 12, duration: 8.2, repeat: -1, yoyo: true, ease: 'sine.inOut' });
        gsap.to('.glow-green', { x: 12, y: -12, duration: 8.8, repeat: -1, yoyo: true, ease: 'sine.inOut' });
        gsap.to('.glow-blue', { x: -14, y: -10, duration: 7.9, repeat: -1, yoyo: true, ease: 'sine.inOut' });
      }
    </script>
  </body>
</html>
