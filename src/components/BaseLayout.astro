---
import "../styles/global.css";
import {
  type Locale,
  type LandingCopy,
  SUPPORTED_LOCALES,
  OG_LOCALES,
  localizedPath,
} from "../lib/i18n";

interface Props {
  locale: Locale;
  copy: LandingCopy;
}

const { locale, copy } = Astro.props;

const SITE_URL = "https://summa.fit";
const OG_IMAGE = `${SITE_URL}/newog-image.png`;
const canonicalPath = localizedPath(locale);
const canonicalUrl = `${SITE_URL}${canonicalPath}`;
const organizationId = `${SITE_URL}/#organization`;
const websiteId = `${SITE_URL}/#website`;
const appId = `${SITE_URL}/#summafit-app`;
const webpageId = `${canonicalUrl}#webpage`;

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": organizationId,
      name: "SummaFit",
      url: SITE_URL,
      logo: {
        "@type": "ImageObject",
        url: `${SITE_URL}/logo.svg`,
      },
    },
    {
      "@type": "WebSite",
      "@id": websiteId,
      name: "SummaFit",
      url: SITE_URL,
      inLanguage: SUPPORTED_LOCALES,
      publisher: { "@id": organizationId },
    },
    {
      "@type": "MobileApplication",
      "@id": appId,
      name: "SummaFit",
      applicationCategory: "HealthApplication",
      applicationSubCategory: "Calorie and nutrition tracking",
      operatingSystem: "iOS 26.0 or later",
      softwareRequirements: "Requires iOS 26.0 or later",
      url: `${SITE_URL}/en/`,
      image: OG_IMAGE,
      description: copy.seoDescription,
      inLanguage: SUPPORTED_LOCALES,
      publisher: { "@id": organizationId },
      featureList: [
        "Calorie and macro tracking",
        "Food barcode scanning",
        "Water and weight tracking",
        "Personal nutrition targets",
        "Optional Apple Health integration",
        "Local-first storage",
      ],
    },
    {
      "@type": "WebPage",
      "@id": webpageId,
      url: canonicalUrl,
      name: copy.seoTitle,
      description: copy.seoDescription,
      inLanguage: locale,
      isPartOf: { "@id": websiteId },
      about: { "@id": appId },
      mainEntity: { "@id": appId },
    },
  ],
};
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={copy.seoDescription} />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <meta name="googlebot" content="index, follow, max-image-preview:large" />
    <meta name="application-name" content="SummaFit" />
    <meta name="apple-mobile-web-app-title" content="SummaFit" />
    <meta name="theme-color" content="#F5F7FA" />
    <meta name="author" content="SummaFit" />

    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/logo.svg" type="image/svg+xml" />

    <link
      rel="alternate"
      hreflang="x-default"
      href={`${SITE_URL}${localizedPath("en")}`}
    />
    {
      SUPPORTED_LOCALES.map((l) => (
        <link
          rel="alternate"
          hreflang={l}
          href={`${SITE_URL}${localizedPath(l)}`}
        />
      ))
    }

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="SummaFit" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content={OG_LOCALES[locale]} />
    {
      SUPPORTED_LOCALES.filter((l) => l !== locale).map((l) => (
        <meta property="og:locale:alternate" content={OG_LOCALES[l]} />
      ))
    }

    <meta property="og:title" content={copy.seoTitle} />
    <meta property="og:description" content={copy.seoDescription} />
    <meta property="og:image" content={OG_IMAGE} />
    <meta property="og:image:secure_url" content={OG_IMAGE} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1731" />
    <meta property="og:image:height" content="909" />
    <meta property="og:image:alt" content={copy.heroAlt} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={copy.seoTitle} />
    <meta name="twitter:description" content={copy.seoDescription} />
    <meta name="twitter:image" content={OG_IMAGE} />
    <meta name="twitter:image:alt" content={copy.heroAlt} />

    <script
      type="application/ld+json"
      set:html={JSON.stringify(structuredData)}
      is:inline
    />
    <title>{copy.seoTitle}</title>
  </head>
  <body>
    <div class="ambient-field" aria-hidden="true">
      <span class="ambient-glow glow-orange"></span>
      <span class="ambient-glow glow-violet"></span>
      <span class="ambient-glow glow-green"></span>
      <span class="ambient-glow glow-blue"></span>
    </div>

    <main id="main-content" class="page-shell">
      <slot />
    </main>

    <script>
      import { gsap } from "gsap";

      const startHeroAnimations = () => {
        const mm = gsap.matchMedia();

        mm.add(
          {
            isDesktop: "(min-width: 900px)",
            reduceMotion: "(prefers-reduced-motion: reduce)",
          },
          (context) => {
            const conditions = context.conditions as
              { isDesktop?: boolean; reduceMotion?: boolean } | undefined;
            const isDesktop = Boolean(conditions?.isDesktop);
            const reduceMotion = Boolean(conditions?.reduceMotion);

            if (reduceMotion) {
              gsap.set(".reveal-soft, .reveal-phone", {
                autoAlpha: 1,
                y: 0,
                scale: 1,
                rotation: 0,
                filter: "blur(0px)",
              });
              return;
            }

            gsap.set(".reveal-soft", {
              autoAlpha: 0,
              y: 18,
              filter: "blur(10px)",
            });
            gsap.set(".reveal-phone", {
              autoAlpha: 0,
              y: isDesktop ? 42 : 24,
              scale: 0.94,
              rotation: isDesktop ? -5.5 : 0,
              filter: "blur(14px)",
              transformOrigin: "50% 70%",
            });

            const intro = gsap.timeline({ defaults: { ease: "power3.out" } });
            intro
              .to(".reveal-soft", {
                autoAlpha: 1,
                y: 0,
                filter: "blur(0px)",
                duration: 0.9,
                stagger: 0.09,
              })
              .to(
                ".reveal-phone",
                {
                  autoAlpha: 1,
                y: 0,
                scale: 1,
                  rotation: isDesktop ? -2.2 : 0,
                  filter: "blur(0px)",
                  duration: 1.18,
                },
                "<0.14",
              );

            gsap.to(".ambient-glow", {
              scale: 1.09,
              opacity: 0.78,
              duration: 5.8,
              repeat: -1,
              yoyo: true,
              ease: "sine.inOut",
              stagger: { each: 0.45, from: "center" },
            });

            gsap.to(".glow-orange", {
              x: 16,
              y: 10,
              duration: 7.4,
              repeat: -1,
              yoyo: true,
              ease: "sine.inOut",
            });
            gsap.to(".glow-violet", {
              x: -14,
              y: 12,
              duration: 8.2,
              repeat: -1,
              yoyo: true,
              ease: "sine.inOut",
            });
            gsap.to(".glow-green", {
              x: 12,
              y: -14,
              duration: 8.8,
              repeat: -1,
              yoyo: true,
              ease: "sine.inOut",
            });
            gsap.to(".glow-blue", {
              x: -16,
              y: -10,
              duration: 7.9,
              repeat: -1,
              yoyo: true,
              ease: "sine.inOut",
            });

            gsap.to(".hero-product-image", {
              y: isDesktop ? -6 : -4,
              rotation: isDesktop ? 0.2 : 0,
              duration: 5.6,
              repeat: -1,
              yoyo: true,
              ease: "sine.inOut",
            });

            if (isDesktop) {
              const hero = document.querySelector<HTMLElement>(".hero");
              const phone = document.querySelector<HTMLElement>(".hero-media");

              if (!hero || !phone) return;

              const rotateXTo = gsap.quickTo(phone, "rotationX", {
                duration: 0.7,
                ease: "power3",
              });
              const rotateYTo = gsap.quickTo(phone, "rotationY", {
                duration: 0.7,
                ease: "power3",
              });

              const handlePointerMove = (event: MouseEvent) => {
                const rect = hero.getBoundingClientRect();
                const x = (event.clientX - rect.left) / rect.width - 0.5;
                const y = (event.clientY - rect.top) / rect.height - 0.5;
                rotateXTo(y * -3.5);
                rotateYTo(x * 4.5);
              };

              const handlePointerLeave = () => {
                rotateXTo(0);
                rotateYTo(0);
              };

              hero.addEventListener("mousemove", handlePointerMove);
              hero.addEventListener("mouseleave", handlePointerLeave);

              return () => {
                hero.removeEventListener("mousemove", handlePointerMove);
                hero.removeEventListener("mouseleave", handlePointerLeave);
              };
            }
          },
        );
      };

      const queueHeroAnimations = () =>
        window.setTimeout(startHeroAnimations, 120);

      const landingIsland = document.querySelector(
        'astro-island[component-export="LandingExperience"]',
      );
      if (landingIsland?.hasAttribute("ssr")) {
        landingIsland.addEventListener("astro:hydrate", queueHeroAnimations, {
          once: true,
        });
      } else {
        queueHeroAnimations();
      }
    </script>
  </body>
</html>
