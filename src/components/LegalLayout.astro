---
import "../styles/global.css";
import {
  LOCALE_LABELS,
  OG_LOCALES,
  SUPPORTED_LOCALES,
  localizedPath,
  type LegalCopy,
  type Locale,
} from "../lib/i18n";

interface Props {
  locale: Locale;
  copy: LegalCopy;
  path: string;
}

const { locale, copy, path } = Astro.props;
const SITE_URL = "https://summa.fit";
const OG_IMAGE = `${SITE_URL}/newog-image.png`;
const canonicalPath = localizedPath(locale, path);
const canonicalUrl = `${SITE_URL}${canonicalPath}`;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={copy.metaDescription} />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#ffffff" />
    <meta name="application-name" content="SummaFit" />
    <meta name="apple-mobile-web-app-title" content="SummaFit" />
    <meta name="author" content="SummaFit" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/logo.svg" type="image/svg+xml" />
    <link
      rel="alternate"
      hreflang="x-default"
      href={`${SITE_URL}${localizedPath("en", path)}`}
    />
    {
      SUPPORTED_LOCALES.map((l) => (
        <link
          rel="alternate"
          hreflang={l}
          href={`${SITE_URL}${localizedPath(l, path)}`}
        />
      ))
    }
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="SummaFit" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content={OG_LOCALES[locale]} />
    <meta property="og:title" content={copy.pageTitle} />
    <meta property="og:description" content={copy.metaDescription} />
    <meta property="og:image" content={OG_IMAGE} />
    <meta property="og:image:alt" content={copy.pageTitle} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={copy.pageTitle} />
    <meta name="twitter:description" content={copy.metaDescription} />
    <meta name="twitter:image" content={OG_IMAGE} />
    <meta name="twitter:image:alt" content={copy.pageTitle} />
    <title>{copy.pageTitle}</title>
  </head>
  <body class="legal-page">
    <header class="legal-header">
      <a class="brand" href={localizedPath(locale)} aria-label="SummaFit home">
        <img src="/logo.svg" alt="" width="28" height="28" />
        <span>SummaFit</span>
      </a>
      <nav class="legal-nav" aria-label={copy.languageLabel}>
        <a class="legal-home-link" href={localizedPath(locale)}>
          {copy.homeLabel}
        </a>
        <div class="legal-lang-list">
          {
            SUPPORTED_LOCALES.map((l) => (
              <a
                href={localizedPath(l, path)}
                hreflang={l}
                aria-current={l === locale ? "page" : undefined}
              >
                {LOCALE_LABELS[l]}
              </a>
            ))
          }
        </div>
      </nav>
    </header>
    <main class="legal-main">
      <slot />
    </main>
  </body>
</html>
