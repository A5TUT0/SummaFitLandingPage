---
import '../styles/global.css';
import {
  Activity,
  Apple,
  ArrowRight,
  BarChart3,
  Bell,
  Camera,
  Check,
  ChevronRight,
  Droplets,
  Flame,
  HeartPulse,
  Home,
  Plus,
  Salad,
  ScanLine,
  ShieldCheck,
  Sparkles,
  Target,
  Utensils,
} from 'lucide-astro';
import { copy, languages, localePath, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = copy[locale];

const macroValues = ['118g', '164g', '54g'];
const macroColors = ['var(--purple-main)', 'var(--cyan-main)', 'var(--fat-main)'];
const macros = t.macros.map((label, index) => ({
  label,
  value: macroValues[index],
  percent: ['82%', '67%', '73%'][index],
  color: macroColors[index],
}));

const mealMeta = [
  { time: '12:40', calories: '520 kcal', icon: Salad },
  { time: '09:15', calories: '240 kcal', icon: Apple },
  { time: '07:50', calories: '160 kcal', icon: Utensils },
];
const meals = t.meals.map((name, index) => ({ name, ...mealMeta[index] }));

const featureIcons = [ScanLine, Droplets, HeartPulse];
const features = t.features.items.map(([title, body], index) => ({
  icon: featureIcons[index],
  title,
  copy: body,
}));

const progressColors = ['var(--orange-main)', 'var(--purple-main)', 'var(--blue-main)'];
const progressValues = ['89%', '94%', '76%'];
const progressCards = t.results.cards.map((label, index) => ({
  label,
  value: progressValues[index],
  color: progressColors[index],
}));

const footerCopy = {
  en: {
    tagline: 'Daily nutrition, hydration, and habits in one calm view.',
    links: ['Privacy', 'Contact', 'Beta'],
  },
  es: {
    tagline: 'Nutricion, hidratacion y habitos diarios en una vista tranquila.',
    links: ['Privacidad', 'Contacto', 'Beta'],
  },
  de: {
    tagline: 'Ernaehrung, Hydration und taegliche Gewohnheiten in einer ruhigen Ansicht.',
    links: ['Datenschutz', 'Kontakt', 'Beta'],
  },
}[locale];
---

<!doctype html>
<html lang={t.htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={t.metaDescription} />
    <link rel="alternate" hreflang="en" href="/" />
    <link rel="alternate" hreflang="es" href="/es/" />
    <link rel="alternate" hreflang="de" href="/de/" />
    <link rel="alternate" hreflang="x-default" href="/" />
    <title>{t.title}</title>
  </head>
  <body>
    <div class="soft-grid pointer-events-none fixed inset-0 z-0"></div>

    <header class="fixed left-0 right-0 top-4 z-50 px-4">
      <nav
        class="glass-nav mx-auto flex h-16 max-w-6xl items-center justify-between rounded-full px-4 sm:px-6"
        aria-label={t.aria.nav}
      >
        <a href={localePath(locale)} class="flex items-center gap-3" aria-label={t.aria.home}>
          <span class="grid size-10 place-items-center rounded-full bg-[var(--orange-main)] text-white shadow-[0_10px_22px_var(--orange-glow)]">
            <Flame size={21} strokeWidth={2.5} />
          </span>
          <span class="text-lg font-semibold tracking-normal">SummaFit</span>
        </a>
        <div class="hidden items-center gap-7 text-sm font-medium text-[var(--text-secondary)] md:flex">
          <a class="transition hover:text-[var(--text-main)]" href="#features">{t.nav.features}</a>
          <a class="transition hover:text-[var(--text-main)]" href="#daily">{t.nav.daily}</a>
          <a class="transition hover:text-[var(--text-main)]" href="#results">{t.nav.results}</a>
        </div>
        <div class="flex items-center gap-2">
          <div class="hidden items-center rounded-full border border-white/70 bg-white/60 p-1 text-xs font-semibold text-[var(--text-secondary)] sm:flex">
            {Object.entries(languages).map(([code, label]) => (
              <a
                class:list={[
                  'rounded-full px-3 py-1.5 transition',
                  code === locale ? 'bg-[var(--text-main)] text-white' : 'hover:text-[var(--text-main)]',
                ]}
                href={localePath(code as Locale)}
                aria-label={label}
              >
                {code.toUpperCase()}
              </a>
            ))}
          </div>
          <a
            href="#download"
            class="inline-flex h-11 items-center gap-2 rounded-full bg-[var(--text-main)] px-5 text-sm font-semibold text-white shadow-lg shadow-black/10 transition hover:-translate-y-0.5"
          >
            {t.nav.cta}
            <ArrowRight size={17} />
          </a>
        </div>
      </nav>
    </header>

    <main class="relative z-10">
      <section class="min-h-screen px-4 pb-16 pt-28 sm:px-6 lg:px-8 lg:pt-32">
        <div class="mx-auto grid max-w-6xl items-center gap-12 lg:grid-cols-[0.96fr_1.04fr]">
          <div class="hero-copy max-w-2xl">
            <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-white/70 bg-white/70 px-4 py-2 text-sm font-semibold text-[var(--orange-deep)] shadow-sm backdrop-blur">
              <Sparkles size={16} />
              {t.hero.eyebrow}
            </div>
            <h1 class="max-w-3xl text-5xl font-semibold leading-[1.02] tracking-normal text-[var(--text-main)] sm:text-6xl lg:text-7xl">
              SummaFit
            </h1>
            <p class="mt-6 max-w-xl text-lg leading-8 text-[var(--text-secondary)] sm:text-xl">
              {t.hero.body}
            </p>
            <div class="mt-9 flex flex-col gap-4 sm:flex-row">
              <a href="#download" class="inline-flex h-14 items-center justify-center gap-3 rounded-full bg-[var(--orange-main)] px-7 text-base font-semibold text-white shadow-[0_14px_34px_var(--orange-glow)] transition hover:-translate-y-1">
                {t.hero.primaryCta}
                <ChevronRight size={20} />
              </a>
              <a href="#features" class="inline-flex h-14 items-center justify-center gap-3 rounded-full border border-white/80 bg-white/70 px-7 text-base font-semibold text-[var(--text-main)] shadow-sm backdrop-blur transition hover:-translate-y-1">
                {t.hero.secondaryCta}
                <BarChart3 size={19} />
              </a>
            </div>
            <div class="mt-10 grid max-w-xl grid-cols-3 gap-3">
              {['92%', '2.4L', '14k'].map((value, index) => (
                <div class="stat rounded-[28px] border border-white/70 bg-white/60 p-4 backdrop-blur">
                  <p class="text-2xl font-semibold">{value}</p>
                  <p class="mt-1 text-sm text-[var(--text-secondary)]">{t.hero.stats[index]}</p>
                </div>
              ))}
            </div>
          </div>

          <div class="hero-visual relative mx-auto w-full max-w-[560px]">
            <div class="float-card card absolute -left-2 top-16 z-20 hidden w-44 p-5 sm:block lg:-left-10">
              <div class="flex items-center gap-3">
                <span class="grid size-11 place-items-center rounded-full bg-[var(--blue-soft)] text-[var(--blue-main)]">
                  <Droplets size={22} />
                </span>
                <div>
                  <p class="text-sm font-semibold">{t.phone.hydration}</p>
                  <p class="text-xs text-[var(--text-secondary)]">1.8 / 2.4 L</p>
                </div>
              </div>
              <div class="mt-4 h-2 overflow-hidden rounded-full bg-[var(--blue-soft)]">
                <div class="h-full w-3/4 rounded-full bg-[var(--blue-main)]"></div>
              </div>
            </div>

            <div class="float-card card absolute -right-1 bottom-28 z-20 hidden w-48 p-5 sm:block lg:-right-8">
              <div class="flex items-center justify-between">
                <span class="grid size-11 place-items-center rounded-full bg-green-50 text-[var(--green-main)]">
                  <Activity size={22} />
                </span>
                <span class="rounded-full bg-green-50 px-3 py-1 text-xs font-semibold text-[var(--green-main)]">+18%</span>
              </div>
              <p class="mt-4 text-sm text-[var(--text-secondary)]">{t.phone.caloriesBurned}</p>
              <p class="mt-1 text-2xl font-semibold">640</p>
            </div>

            <div class="phone-shell motion-safe relative mx-auto w-full max-w-[390px] rounded-[48px] border border-white/80 bg-[#f7f8fa] p-3">
              <div class="overflow-hidden rounded-[38px] border border-[#eceef1] bg-[#f7f8fa]">
                <div class="px-5 pb-5 pt-4">
                  <div class="mb-5 flex items-center justify-between">
                    <div>
                      <p class="text-sm text-[var(--text-secondary)]">{t.phone.today}</p>
                      <p class="text-xl font-semibold">{t.phone.dailySummary}</p>
                    </div>
                    <button class="grid size-11 place-items-center rounded-full border border-[#eaebee] bg-white text-[var(--text-main)] shadow-sm" aria-label={t.aria.notifications}>
                      <Bell size={19} />
                    </button>
                  </div>

                  <section class="card p-5">
                    <div class="flex items-center justify-between">
                      <div>
                        <p class="text-sm font-medium text-[var(--text-secondary)]">{t.phone.calories}</p>
                        <p class="mt-1 text-4xl font-semibold tracking-normal">1,680</p>
                        <p class="mt-1 text-sm text-[var(--text-muted)]">{t.phone.caloriesGoal}</p>
                      </div>
                      <div class="ring-progress grid size-28 place-items-center rounded-full">
                        <div class="grid size-20 place-items-center rounded-full bg-white">
                          <Flame size={30} class="text-[var(--orange-main)]" />
                        </div>
                      </div>
                    </div>
                    <div class="mt-5 grid grid-cols-3 gap-2">
                      {macros.map((macro) => (
                        <div class="rounded-[22px] bg-[#f7f8fa] p-3">
                          <p class="text-[11px] font-medium text-[var(--text-secondary)]">{macro.label}</p>
                          <p class="mt-1 text-base font-semibold">{macro.value}</p>
                          <div class="mt-2 h-1.5 rounded-full bg-[var(--ring-bg)]">
                            <div class="h-full rounded-full" style={`width:${macro.percent}; background:${macro.color}`}></div>
                          </div>
                        </div>
                      ))}
                    </div>
                  </section>

                  <section class="card mt-4 p-5">
                    <div class="flex items-center justify-between">
                      <div>
                        <p class="text-sm font-semibold">{t.phone.water}</p>
                        <p class="mt-1 text-sm text-[var(--text-secondary)]">{t.phone.waterProgress}</p>
                      </div>
                      <button class="water-button inline-flex items-center gap-2 text-sm font-semibold">
                        <Plus size={17} />
                        250 ml
                      </button>
                    </div>
                    <div class="mt-4 grid grid-cols-8 gap-1.5">
                      {Array.from({ length: 8 }).map((_, index) => (
                        <span class:list={['h-9 rounded-full', index < 6 ? 'bg-[var(--blue-main)]' : 'bg-[var(--blue-soft)]']} />
                      ))}
                    </div>
                  </section>

                  <section class="card mt-4 p-5">
                    <div class="mb-4 flex items-center justify-between">
                      <p class="font-semibold">{t.phone.meals}</p>
                      <button class="grid size-9 place-items-center rounded-full bg-[var(--orange-main)] text-white" aria-label={t.aria.addMeal}>
                        <Plus size={18} />
                      </button>
                    </div>
                    <div class="space-y-3">
                      {meals.map((meal) => (
                        <div class="flex items-center gap-3 rounded-[24px] bg-[#f7f8fa] p-3">
                          <span class="grid size-11 place-items-center rounded-full bg-white text-[var(--orange-main)] shadow-sm">
                            <meal.icon size={20} />
                          </span>
                          <div class="min-w-0 flex-1">
                            <p class="truncate text-sm font-semibold">{meal.name}</p>
                            <p class="text-xs text-[var(--text-secondary)]">{meal.time}</p>
                          </div>
                          <p class="text-xs font-semibold text-[var(--text-secondary)]">{meal.calories}</p>
                        </div>
                      ))}
                    </div>
                  </section>
                </div>

                <div class="px-5 pb-5">
                  <div class="bottom-nav grid grid-cols-4 items-center gap-1 p-1.5">
                    <button class="grid h-12 place-items-center rounded-full bg-[#f2f2f2] text-[var(--orange-main)]" aria-label={t.aria.homeTab}>
                      <Home size={20} />
                    </button>
                    <button class="grid h-12 place-items-center rounded-full text-[var(--text-muted)]" aria-label={t.aria.activityTab}>
                      <Activity size={20} />
                    </button>
                    <button class="mx-auto grid size-16 -translate-y-5 place-items-center rounded-full bg-gradient-to-b from-[#f26a00] to-[#d84b00] text-white shadow-[0_12px_32px_rgba(216,75,0,0.38)]" aria-label={t.aria.scanMeal}>
                      <Camera size={24} />
                    </button>
                    <button class="grid h-12 place-items-center rounded-full text-[var(--text-muted)]" aria-label={t.aria.goalsTab}>
                      <Target size={20} />
                    </button>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section id="features" class="px-4 py-20 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-6xl">
          <div class="section-title max-w-2xl">
            <p class="text-sm font-semibold uppercase text-[var(--orange-deep)]">{t.features.eyebrow}</p>
            <h2 class="mt-3 text-4xl font-semibold tracking-normal sm:text-5xl">{t.features.title}</h2>
          </div>
          <div class="mt-10 grid gap-5 md:grid-cols-3">
            {features.map((feature) => (
              <article class="feature-card card p-7">
                <span class="grid size-13 place-items-center rounded-full bg-[#f7f8fa] text-[var(--orange-main)]">
                  <feature.icon size={24} />
                </span>
                <h3 class="mt-6 text-xl font-semibold">{feature.title}</h3>
                <p class="mt-3 leading-7 text-[var(--text-secondary)]">{feature.copy}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section id="daily" class="px-4 py-20 sm:px-6 lg:px-8">
        <div class="mx-auto grid max-w-6xl items-center gap-8 lg:grid-cols-[0.9fr_1.1fr]">
          <div class="section-title">
            <p class="text-sm font-semibold uppercase text-[var(--blue-main)]">{t.daily.eyebrow}</p>
            <h2 class="mt-3 text-4xl font-semibold tracking-normal sm:text-5xl">{t.daily.title}</h2>
            <p class="mt-5 text-lg leading-8 text-[var(--text-secondary)]">{t.daily.body}</p>
          </div>
          <div class="grid gap-4 sm:grid-cols-2">
            <div class="routine-card card p-7">
              <div class="flex items-center justify-between">
                <span class="grid size-12 place-items-center rounded-full bg-[var(--blue-soft)] text-[var(--blue-main)]"><Droplets size={24} /></span>
                <span class="text-sm font-semibold text-[var(--blue-main)]">75%</span>
              </div>
              <h3 class="mt-8 text-2xl font-semibold">{t.daily.hydration}</h3>
              <div class="mt-5 h-3 overflow-hidden rounded-full bg-[var(--blue-soft)]"><div class="h-full w-3/4 rounded-full bg-[var(--blue-main)]"></div></div>
            </div>
            <div class="routine-card card p-7">
              <div class="flex items-center justify-between">
                <span class="grid size-12 place-items-center rounded-full bg-orange-50 text-[var(--orange-main)]"><Flame size={24} /></span>
                <span class="text-sm font-semibold text-[var(--orange-deep)]">{t.daily.caloriesFree}</span>
              </div>
              <h3 class="mt-8 text-2xl font-semibold">{t.daily.energy}</h3>
              <p class="mt-3 leading-7 text-[var(--text-secondary)]">{t.daily.energyBody}</p>
            </div>
            <div class="routine-card card p-7 sm:col-span-2">
              <div class="flex flex-col gap-5 sm:flex-row sm:items-center sm:justify-between">
                <div>
                  <h3 class="text-2xl font-semibold">{t.daily.habits}</h3>
                  <p class="mt-2 text-[var(--text-secondary)]">{t.daily.habitsBody}</p>
                </div>
                <div class="flex gap-2">
                  {Array.from({ length: 4 }).map(() => <span class="grid size-12 place-items-center rounded-full bg-green-50 text-[var(--green-main)]"><Check size={20} /></span>)}
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section id="results" class="px-4 py-20 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-6xl">
          <div class="card overflow-hidden p-6 sm:p-8 lg:p-10">
            <div class="grid gap-10 lg:grid-cols-[0.85fr_1.15fr] lg:items-center">
              <div class="section-title">
                <p class="text-sm font-semibold uppercase text-[var(--green-main)]">{t.results.eyebrow}</p>
                <h2 class="mt-3 text-4xl font-semibold tracking-normal sm:text-5xl">{t.results.title}</h2>
                <p class="mt-5 text-lg leading-8 text-[var(--text-secondary)]">{t.results.body}</p>
              </div>
              <div class="grid gap-4 sm:grid-cols-3">
                {progressCards.map((card) => (
                  <div class="progress-card rounded-[30px] border border-[#eceef1] bg-[#f7f8fa] p-5">
                    <div class="mx-auto grid size-28 place-items-center rounded-full" style={`background: conic-gradient(${card.color} 0 ${card.value}, #eceef1 ${card.value} 100%)`}>
                      <div class="grid size-20 place-items-center rounded-full bg-white"><span class="text-xl font-semibold">{card.value}</span></div>
                    </div>
                    <p class="mt-5 text-center font-semibold">{card.label}</p>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </section>

      <section id="download" class="px-4 py-24 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-4xl text-center">
          <div class="section-title">
            <p class="text-sm font-semibold uppercase text-[var(--orange-deep)]">{t.download.eyebrow}</p>
            <h2 class="mt-3 text-4xl font-semibold tracking-normal sm:text-6xl">{t.download.title}</h2>
            <p class="mx-auto mt-5 max-w-2xl text-lg leading-8 text-[var(--text-secondary)]">{t.download.body}</p>
          </div>
          <div class="mt-9 flex flex-col items-center justify-center gap-4 sm:flex-row">
            <a href="mailto:hola@summafit.app" class="inline-flex h-14 items-center justify-center gap-3 rounded-full bg-[var(--orange-main)] px-8 text-base font-semibold text-white shadow-[0_14px_34px_var(--orange-glow)] transition hover:-translate-y-1">
              {t.download.cta}
              <ArrowRight size={20} />
            </a>
            <a href="#" class="inline-flex h-14 items-center justify-center gap-3 rounded-full border border-white/80 bg-white/70 px-8 text-base font-semibold text-[var(--text-main)] shadow-sm backdrop-blur transition hover:-translate-y-1">
              <ShieldCheck size={20} />
              {t.download.badge}
            </a>
          </div>
        </div>
      </section>
    </main>

    <footer class="relative z-10 px-4 pb-10 sm:px-6 lg:px-8">
      <div class="mx-auto flex max-w-6xl flex-col gap-5 border-t border-white/70 pt-8 text-sm text-[var(--text-secondary)] sm:flex-row sm:items-center sm:justify-between">
        <div class="flex items-center gap-3">
          <span class="grid size-9 place-items-center rounded-full bg-[var(--orange-main)] text-white shadow-[0_10px_22px_var(--orange-glow)]">
            <Flame size={18} strokeWidth={2.5} />
          </span>
          <div>
            <p class="font-semibold text-[var(--text-main)]">SummaFit</p>
            <p>{footerCopy.tagline}</p>
          </div>
        </div>
        <div class="flex flex-wrap gap-4 font-semibold">
          {footerCopy.links.map((link) => (
            <a class="transition hover:text-[var(--orange-main)]" href="#download">{link}</a>
          ))}
        </div>
      </div>
    </footer>

    <script>
      import { gsap } from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';

      gsap.registerPlugin(ScrollTrigger);

      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (!prefersReduced) {
        gsap
          .timeline({ defaults: { ease: 'power3.out' } })
          .from('.glass-nav', { y: -24, opacity: 0, duration: 0.8 })
          .from('.hero-copy > *', { y: 28, opacity: 0, duration: 0.8, stagger: 0.08 }, '-=0.35')
          .from('.phone-shell', { y: 44, rotate: -2, opacity: 0, duration: 1 }, '-=0.55')
          .from('.float-card', { scale: 0.9, y: 24, opacity: 0, duration: 0.75, stagger: 0.12 }, '-=0.55');

        gsap.to('.phone-shell', { y: -16, rotate: 1.2, duration: 4.4, repeat: -1, yoyo: true, ease: 'sine.inOut' });
        gsap.to('.float-card', { y: -12, duration: 3.3, repeat: -1, yoyo: true, stagger: 0.35, ease: 'sine.inOut' });

        gsap.utils.toArray<HTMLElement>('.section-title, .feature-card, .routine-card, .progress-card').forEach((element) => {
          gsap.from(element, {
            y: 32,
            opacity: 0,
            duration: 0.8,
            ease: 'power3.out',
            scrollTrigger: { trigger: element, start: 'top 82%' },
          });
        });

        gsap.to('.ring-progress', { rotate: 360, duration: 18, repeat: -1, ease: 'none' });
      }
    </script>
  </body>
</html>
