---
import '../styles/global.css';
import { Flame, Sparkles } from 'lucide-astro';
import { copy, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = copy[locale];
---

<!doctype html>
<html lang={t.htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={t.metaDescription} />
    <link rel="alternate" hreflang="en" href="/" />
    <link rel="alternate" hreflang="es" href="/es/" />
    <link rel="alternate" hreflang="de" href="/de/" />
    <link rel="alternate" hreflang="x-default" href="/" />
    <title>{t.title}</title>
  </head>
  <body>
    <main class="relative min-h-screen overflow-hidden px-5 py-6 sm:px-8">
      <a href="/" class="quiet-brand" aria-label={t.aria.home}>
        <span class="brand-dot"><Flame size={17} strokeWidth={2.3} /></span>
        <span>SummaFit</span>
      </a>

      <section class="minimal-hero mx-auto grid min-h-[calc(100vh-3rem)] max-w-6xl items-center gap-12 lg:grid-cols-[0.92fr_1.08fr]">
        <div class="hero-copy">
          <p class="hero-kicker">
            <Sparkles size={15} />
            {t.hero.eyebrow}
          </p>
          <h1 class="hero-title">SummaFit</h1>
          <p class="hero-text">{t.hero.body}</p>
        </div>

        <div class="spin-stage" aria-hidden="true">
          <div class="summa-orbit">
            <span class="orbit-dot orbit-dot-orange"></span>
            <span class="orbit-dot orbit-dot-lavender"></span>
            <span class="orbit-dot orbit-dot-mint"></span>
            <span class="orbit-dot orbit-dot-sky"></span>
            <span class="orbit-core"></span>
            <span class="orbit-line orbit-line-one"></span>
            <span class="orbit-line orbit-line-two"></span>
          </div>
        </div>
      </section>
    </main>

    <script>
      import { gsap } from 'gsap';

      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (!prefersReduced) {
        gsap
          .timeline({ defaults: { ease: 'power4.out' } })
          .from('.quiet-brand', { y: -14, opacity: 0, duration: 0.7 })
          .from('.hero-kicker', { y: 18, opacity: 0, duration: 0.65 }, '-=0.25')
          .from('.hero-title', { yPercent: 14, opacity: 0, duration: 0.95 }, '-=0.2')
          .from('.hero-text', { y: 20, opacity: 0, duration: 0.75 }, '-=0.45')
          .from('.summa-orbit', { scale: 0.82, opacity: 0, rotate: -20, duration: 1.2 }, '-=0.65')
          .from('.orbit-dot', { scale: 0, opacity: 0, duration: 0.65, stagger: 0.08 }, '-=0.55');

        gsap.to('.summa-orbit', { rotate: 360, duration: 32, repeat: -1, ease: 'none' });
        gsap.to('.orbit-core', { scale: 1.08, duration: 3.8, repeat: -1, yoyo: true, ease: 'sine.inOut' });
        gsap.to('.orbit-line-one', { rotate: 360, duration: 18, repeat: -1, ease: 'none' });
        gsap.to('.orbit-line-two', { rotate: -360, duration: 24, repeat: -1, ease: 'none' });
      }
    </script>
  </body>
</html>
