---
import type { LegalCopy } from "../lib/i18n";

interface Props {
  copy: LegalCopy;
}

const { copy } = Astro.props;
---

<div class="doc-wrap">

  <div class="doc-intro">
    <span class="doc-badge">{copy.eyebrow}</span>
    <h1 class="doc-title">{copy.heading}</h1>
    <p class="doc-lead">{copy.intro}</p>
    <p class="doc-date">
      <span>{copy.updatedLabel}:&nbsp;</span><time>{copy.updatedAt}</time>
    </p>
  </div>

  <div class="doc-summary" role="region" aria-label={copy.summaryLabel}>
    <p class="doc-summary-label">{copy.summaryLabel}</p>
    <dl class="doc-summary-grid">
      {
        copy.summaryItems.map((item) => (
          <div>
            <dt>{item.term}</dt>
            <dd>{item.detail}</dd>
          </div>
        ))
      }
    </dl>
  </div>

  <div class="doc-body">
    <nav class="doc-toc" aria-label={copy.contentsNavigationLabel}>
      <p class="doc-toc-label">{copy.contentsLabel}</p>
      <ol>
        {
          copy.sections.map((section, index) => (
            <li>
              <a href={`#section-${index + 1}`}>
                <span class="doc-toc-num">{String(index + 1).padStart(2, "0")}</span>
                {section.title}
              </a>
            </li>
          ))
        }
      </ol>
    </nav>

    <div class="doc-sections">
      {
        copy.sections.map((section, index) => (
          <section id={`section-${index + 1}`} class="doc-section">
            <p class="doc-section-num">{String(index + 1).padStart(2, "0")}</p>
            <h2>{section.title}</h2>
            {section.body.map((paragraph) => (
              <p>{paragraph}</p>
            ))}
          </section>
        ))
      }
    </div>
  </div>

  <footer class="doc-footer">
    <p>{copy.note}</p>
  </footer>

</div>
