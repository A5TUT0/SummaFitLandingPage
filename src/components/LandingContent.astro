---
import type { LandingCopy } from "../lib/i18n";

interface Props {
  copy: LandingCopy;
  installUrl: string;
  privacyHref: string;
}

const { copy, installUrl, privacyHref } = Astro.props;
const content = copy.content;
---

<section class="landing-content-section" id="features" aria-labelledby="features-title">
  <div class="landing-section-heading">
    <p class="content-eyebrow">{content.featuresEyebrow}</p>
    <h2 id="features-title">{content.featuresTitle}</h2>
    <p>{content.featuresIntro}</p>
  </div>

  <div class="feature-grid">
    {
      content.features.map((feature, index) => (
        <article class="feature-card">
          <span class="feature-number" aria-hidden="true">
            {String(index + 1).padStart(2, "0")}
          </span>
          <h3>{feature.title}</h3>
          <p>{feature.description}</p>
        </article>
      ))
    }
  </div>
</section>

<section class="landing-content-section how-section" id="how-it-works" aria-labelledby="how-title">
  <div class="landing-section-heading">
    <p class="content-eyebrow">{content.howEyebrow}</p>
    <h2 id="how-title">{content.howTitle}</h2>
    <p>{content.howIntro}</p>
  </div>

  <ol class="steps-grid">
    {
      content.steps.map((step, index) => (
        <li>
          <span aria-hidden="true">{index + 1}</span>
          <div>
            <h3>{step.title}</h3>
            <p>{step.description}</p>
          </div>
        </li>
      ))
    }
  </ol>
</section>

<section class="privacy-panel" aria-labelledby="privacy-title">
  <div>
    <p class="content-eyebrow">{content.privacyEyebrow}</p>
    <h2 id="privacy-title">{content.privacyTitle}</h2>
    <p>{content.privacyDescription}</p>
    <a href={privacyHref}>{copy.privacyPolicy} <span aria-hidden="true">→</span></a>
  </div>
  <ul>
    {
      content.privacyPoints.map((point) => (
        <li>
          <span aria-hidden="true">✓</span>
          {point}
        </li>
      ))
    }
  </ul>
</section>

<section class="landing-content-section faq-section" id="faq" aria-labelledby="faq-title">
  <div class="landing-section-heading">
    <p class="content-eyebrow">{content.faqEyebrow}</p>
    <h2 id="faq-title">{content.faqTitle}</h2>
  </div>

  <div class="landing-faq-list">
    {
      content.faqs.map((faq) => (
        <details>
          <summary>{faq.question}</summary>
          <p>{faq.answer}</p>
        </details>
      ))
    }
  </div>
</section>

<section class="landing-final-cta" aria-labelledby="final-cta-title">
  <div>
    <h2 id="final-cta-title">{content.ctaTitle}</h2>
    <p>{content.ctaDescription}</p>
  </div>
  <a class="button" href={installUrl}>
    {copy.cta} <span aria-hidden="true">↗</span>
  </a>
</section>
